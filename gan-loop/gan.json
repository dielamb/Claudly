{
  "default_threshold": 8.5,
  "code_threshold": 9.0,
  "max_iterations": 3,
  "escalation": "accept-with-notes",
  "resume": false,

  "architecture": {
    "rubric_isolation": true,
    "generator_sees_rubric": false,
    "feedback_sanitizer": "gan-feedback-sanitizer",
    "generator_reads": ["brief", "generator-note.md"],
    "evaluator_reads": ["draft.md", "rubric"]
  },

  "profiles": {
    "fast": {
      "generator": { "agent": "gan-generator" },
      "evaluator": {
        "agent": "codex",
        "command": "/codex:adversarial-review",
        "criteria_file": "rubrics/[task]-rubric.md"
      },
      "threshold": 8.0,
      "max_iterations": 2
    },
    "default": {
      "generator": { "agent": "gan-generator" },
      "evaluator": {
        "agent": "codex",
        "command": "/codex:adversarial-review",
        "criteria_file": "rubrics/[task]-rubric.md"
      },
      "threshold": 8.5,
      "max_iterations": 3
    },
    "code": {
      "generator": { "agent": "gan-generator" },
      "evaluator": {
        "agent": "codex",
        "command": "/codex:adversarial-review",
        "criteria_file": "rubrics/[task]-rubric.md"
      },
      "threshold": 9.0,
      "max_iterations": 3
    }
  }
}
