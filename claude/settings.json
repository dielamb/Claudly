{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_V3_ENABLED": "true",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  },
  "attribution": {
    "commit": "Co-Authored-By: claude-flow <ruv@ruv.net>",
    "pr": "🤖 Generated with [claude-flow](https://github.com/ruvnet/claude-flow)"
  },
  "permissions": {
    "allow": [
      "Bash(npx @claude-flow*)",
      "Bash(npx claude-flow*)",
      "Bash(node .claude/*)",
      "mcp__claude-flow__:*",
      "mcp__chrome-devtools__*",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_screenshot",
      "mcp__plugin_figma_figma__generate_figma_design",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_code_connect_map",
      "WebSearch",
      "WebFetch(domain:wonjyou.studio)",
      "WebFetch(domain:www.wonjyou.com)",
      "WebFetch(domain:www.figma.com)",
      "WebFetch(domain:developers.figma.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:api.scryfall.com)",
      "WebFetch(domain:skillsmp.com)",
      "Bash(lsof -i :8734*)",
      "Bash(curl -s -o /dev/null -w *http://localhost:8734*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOME__/.claude/helpers/kill-switch.sh",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" pre-bash'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "lean-ctx hook rewrite"
          }
        ]
      },
      {
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory",
        "hooks": [
          {
            "type": "command",
            "command": "lean-ctx hook redirect"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" pre-edit'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOME__/.claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" post-edit'",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" post-bash'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOME__/.claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/vault-quality-checker.cjs\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-read-tracker.js\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/prompt-enrichment.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" route'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/synthesis-context-injector.cjs\"",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/url-ingest-detector.cjs\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST http://localhost:7337/message -H 'Content-Type: application/json' -d '{\"type\":\"thinking\",\"text\":\"Pracuję...\",\"context\":\"\"}' > /dev/null 2>&1 || true",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/project-scope-filter.cjs\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "touch ~/.claude/AUTO_TLDR_DISABLED",
            "timeout": 1000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__HOME__/.claude/helpers-user/verify-integrity.sh\"",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" session-restore'",
            "timeout": 15000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/obsidian-vault-indexer.cjs\"",
            "timeout": 15000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/dreamer-rules-indexer.cjs\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers/auto-memory-hook.mjs\" import",
            "timeout": 30000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__HOME__/.claude/helpers/learning-hooks.sh\" session-start",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/obsidian-extended-loader.cjs\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/graphify-intelligence.cjs\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/quality-rescorer.cjs\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOME__/.claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" session-end'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers-user/router-retention.cjs\"",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers/ewc-consolidate.mjs\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__HOME__/.claude/helpers/learning-hooks.sh\" session-end",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" compact-manual'"
          },
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" session-end'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" compact-auto'"
          },
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" session-end'",
            "timeout": 6000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" status'",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" post-task'",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" notify'",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"__HOME__/.claude/helpers/hook-handler.cjs\" session-end'",
            "timeout": 8000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers/hook-handler.cjs\" post-task",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/helpers/sona-trigger.mjs\"",
            "timeout": 8000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s --max-time 1 -X POST http://localhost:7337/message -H 'Content-Type: application/json' -d '{\"type\":\"idle\",\"text\":\"Czekam na kolejne zadanie.\",\"context\":\"\"}' > /dev/null 2>&1 || true",
            "timeout": 2000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'exec node \"__HOME__/.claude/helpers/statusline.cjs\"'"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "codex@openai-codex": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "impeccable@impeccable": true,
    "stripe@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "verbose": true,
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browserUrl",
        "http://127.0.0.1:9222"
      ]
    }
  },
  "claudeFlow": {
    "version": "3.0.0",
    "enabled": true,
    "platform": {
      "os": "darwin",
      "arch": "arm64",
      "shell": "zsh"
    },
    "modelPreferences": {
      "default": "claude-opus-4-6",
      "routing": "claude-haiku-4-5-20251001"
    },
    "agentTeams": {
      "enabled": true,
      "teammateMode": "auto",
      "taskListEnabled": true,
      "mailboxEnabled": true,
      "coordination": {
        "autoAssignOnIdle": true,
        "trainPatternsOnComplete": true,
        "notifyLeadOnComplete": true,
        "sharedMemoryNamespace": "agent-teams"
      },
      "hooks": {
        "teammateIdle": {
          "enabled": true,
          "autoAssign": true,
          "checkTaskList": true
        },
        "taskCompleted": {
          "enabled": true,
          "trainPatterns": true,
          "notifyLead": true
        }
      }
    },
    "swarm": {
      "topology": "hierarchical-mesh",
      "maxAgents": 15
    },
    "memory": {
      "backend": "hybrid",
      "enableHNSW": true,
      "learningBridge": {
        "enabled": true
      },
      "memoryGraph": {
        "enabled": true
      },
      "agentScopes": {
        "enabled": true
      }
    },
    "neural": {
      "enabled": true
    },
    "learning": {
      "enabled": true,
      "retention": {
        "shortTerm": "24h",
        "longTerm": "30d"
      }
    }
  }
}
